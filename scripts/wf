#!/usr/bin/env bash
set -euo pipefail
export PYTHONDONTWRITEBYTECODE="${PYTHONDONTWRITEBYTECODE:-1}"

SOURCE="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SOURCE="$(readlink -f "$SOURCE")"
fi
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE")" && pwd)"
PROG="$(basename -- "$0")"
WORKFLOW_ROOT="$(cd -- "$SCRIPT_DIR/../../.." && pwd)"
export WORKFLOW_HOME="${WORKFLOW_HOME:-$HOME/.agents/workflow-system}"
TUI_PYTHON="${WORKFLOW_TUI_PYTHON:-$WORKFLOW_HOME/.venv/bin/python}"
LEGACY_TUI_PYTHON="$WORKFLOW_ROOT/workflow-system/.venv/bin/python"

python_for_tui() {
  if [[ -x "$TUI_PYTHON" ]]; then
    printf '%s\n' "$TUI_PYTHON"
  elif [[ -x "$LEGACY_TUI_PYTHON" ]]; then
    printf '%s\n' "$LEGACY_TUI_PYTHON"
  else
    printf '%s\n' python3
  fi
}

usage() {
  cat <<USAGE
$PROG - agent workflow helper

Usage:
  $PROG tui
  $PROG start <goal> [workflow_start.py args...]
  $PROG apply <workflow-json-or-script> [workflow_apply.py args...]
  $PROG exec <workflow-json-or-script> [workflow_apply.py args...]
  $PROG run [workflow_run.py args...]
  $PROG run-codex [workflow_run_codex.py args...]
  $PROG runner-matrix [workflow_runner_matrix.py args...]
  $PROG fibonacci-stress [workflow_fibonacci_stress.py args...]
  $PROG state [workflow_state.py args...]
  $PROG list [workflow_state.py list args...]
  $PROG show <run-id> [workflow_state.py show args...]
  $PROG init [workflow_state.py init args...]
  $PROG add-phase [workflow_state.py add-phase args...]
  $PROG update-phase [workflow_state.py update-phase args...]
  $PROG add-agent [workflow_state.py add-agent args...]
  $PROG update-agent [workflow_state.py update-agent args...]
  $PROG event [workflow_state.py event args...]
  $PROG decision [workflow_state.py decision args...]
  $PROG artifact [workflow_state.py artifact args...]
  $PROG set-status [workflow_state.py set-status args...]
  $PROG pause <run-id> [--reason ...]
  $PROG resume <run-id> [--reason ...]
  $PROG stop <run-id> [--reason ...] [--no-terminate]
  $PROG status [workflow_ops.py status args...]
  $PROG last [workflow_ops.py last args...]
  $PROG open [workflow_tui.py args...]
  $PROG doctor [workflow_ops.py doctor args...]
  $PROG check <run-id> [workflow_ops.py check args...]
  $PROG verify <run-id> [workflow_ops.py verify args...]
  $PROG done <run-id> [workflow_ops.py done args...]
  $PROG block <run-id> <reason>
  $PROG preview [workflow_ops.py preview args...]
USAGE
}

case "$PROG" in
  workflow-tui)
    cmd="tui"
    ;;
  workflow-state)
    cmd="state"
    ;;
  workflow-run-codex)
    cmd="run-codex"
    ;;
  workflow-run)
    cmd="run"
    ;;
  *)
    cmd="${1:-help}"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    ;;
esac

case "$cmd" in
  tui)
    exec "$(python_for_tui)" "$SCRIPT_DIR/workflow_tui.py" "$@"
    ;;
  start)
    exec python3 "$SCRIPT_DIR/workflow_start.py" "$@"
    ;;
  apply|exec)
    exec python3 "$SCRIPT_DIR/workflow_apply.py" "$@"
    ;;
  run)
    exec python3 "$SCRIPT_DIR/workflow_run.py" "$@"
    ;;
  run-codex)
    exec python3 "$SCRIPT_DIR/workflow_run_codex.py" "$@"
    ;;
  runner-matrix|matrix|runner-smoke)
    exec python3 "$SCRIPT_DIR/workflow_runner_matrix.py" "$@"
    ;;
  status|last|doctor|check|verify|done|block|preview|pause|resume|stop)
    exec python3 "$SCRIPT_DIR/workflow_ops.py" "$cmd" "$@"
    ;;
  open)
    exec "$(python_for_tui)" "$SCRIPT_DIR/workflow_tui.py" "$@"
    ;;
  fibonacci-stress|fib-stress)
    exec python3 "$SCRIPT_DIR/workflow_fibonacci_stress.py" "$@"
    ;;
  state)
    exec python3 "$SCRIPT_DIR/workflow_state.py" "$@"
    ;;
  list|show|init|add-phase|update-phase|add-agent|update-agent|event|decision|artifact|set-status|demo)
    exec python3 "$SCRIPT_DIR/workflow_state.py" "$cmd" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "$PROG: unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
